{erl_opts, [debug_info]}.
{deps, [
    {opentelemetry, "~> 1.0"},
    {opentelemetry_api, "~> 1.0"},
    {opentelemetry_semantic_conventions, "~> 1.0"}
]}.

{project_plugins, [erlfmt, rebar3_hex, {rebar3_ex_doc, "~> 0.2.31"}]}.

{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {extras, ["README.md", "LICENSE.md"]},
    {main, "README.md"},
    {source_url, "https://github.com/breakroom/opentelemetry_heroku"}
]}.

